# 复制为 airflow/.env 后由 docker compose 读取（用于变量替换，勿提交 .env）
# Linux 建议设置为本机 UID，避免 logs 目录属主为 root：echo $(id -u)
AIRFLOW_UID=50000

# Airflow Web 登录（airflow-init 首次创建）
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# 可选：覆盖 DAG 内 BashOperator 使用的 ETL 参数（与仓库根 .env 中同名变量二选一即可）
# ETL_TARGET=duckdb
# ETL_DATA_SOURCE=csv
# ETL_POSTGRES_DSN=
