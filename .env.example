# 复制本文件为项目根目录下的 `.env` 并填入真实值（`.env` 已被 .gitignore 忽略，勿提交仓库）。
# PostgreSQL / Supabase 连接串
# 例子：postgresql://postgres:password@localhost:5432/etl_learning
ETL_POSTGRES_DSN=

# Airflow 可选环境变量
ETL_TARGET=duckdb
ETL_DATA_SOURCE=csv
ETL_PROJECT_ROOT=.

# Shopify Admin REST（仅在 python -m etl_project --source shopify 时需要）
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_xxx
# SHOPIFY_API_VERSION=2024-10
