# 复制本文件为项目根目录下的 `.env` 并填入真实值（`.env` 已被 .gitignore 忽略，勿提交仓库）。
# PostgreSQL / Supabase 连接串
# 例子：postgresql://postgres:password@localhost:5432/etl_learning
ETL_POSTGRES_DSN=

# Airflow 可选环境变量
ETL_TARGET=duckdb
ETL_DATA_SOURCE=csv
ETL_PROJECT_ROOT=.

# Shopify Admin REST（仅在 python -m etl_project --source shopify 时需要）
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
# 可选：Storefront API（本仓库 Admin GraphQL 拉数不使用，仅占位）
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# 兼容旧名：SHOPIFY_ACCESS_TOKEN=shpat_xxx
# Admin GraphQL 路径为 /admin/api/{SHOPIFY_API_VERSION}/graphql.json（与前端 lib/constants 对齐）
# 默认不写则代码内为 2025-10，等同 SHOPIFY_ADMIN_GRAPHQL_API_ENDPOINT=/admin/api/2025-10/graphql.json
# 若走 Partner Dev Dashboard 那套端点（等同 SHOPIFY_ADMIN_GRAPHQL_API_ENDPOINT_DEV_DASHBOARD），可设为：
# SHOPIFY_API_VERSION=2026-01
